<Window x:Class="CyberClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberControl Lock"
        WindowStyle="None"
        WindowState="Maximized"
        Topmost="True"
        ResizeMode="NoResize"
        Background="#0A0A0B"
        ShowInTaskbar="True">
    <Grid>
        <StackPanel x:Name="LockPanel" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="🔒"
                       FontSize="72"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,24"/>
            <TextBlock Text="PC VERROUILLÉ"
                       FontSize="36"
                       FontWeight="Bold"
                       Foreground="#FAFAFA"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,12"/>
            <TextBlock Text="Code ticket ou session libre (paiement à la fin)"
                       FontSize="18"
                       Foreground="#A1A1AA"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,32"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBox x:Name="CodeInput"
                         Width="200"
                         Height="40"
                         FontSize="16"
                         FontFamily="Consolas"
                         Background="#18181B"
                         Foreground="#FAFAFA"
                         BorderBrush="#3F3F46"
                         Padding="8,4"
                         VerticalContentAlignment="Center"
                         MaxLength="9"
                         KeyDown="CodeInput_KeyDown"/>
                <Button x:Name="UnlockButton"
                        Content="Déverrouiller"
                        Width="140"
                        Height="40"
                        Margin="12,0,0,0"
                        Background="#059669"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="14"
                        Cursor="Hand"
                        Click="UnlockButton_Click"/>
            </StackPanel>
            <Button x:Name="PostpaidStartButton"
                    Content="Session libre"
                    Width="220"
                    Height="40"
                    Margin="0,16,0,0"
                    Background="#2563EB"
                    Foreground="White"
                    BorderThickness="0"
                    FontSize="14"
                    Cursor="Hand"
                    Click="PostpaidStartButton_Click"/>
            <TextBlock x:Name="StatusText"
                       FontSize="14"
                       Foreground="#EF4444"
                       HorizontalAlignment="Center"
                       Margin="0,16,0,0"
                       Text=""/>
            <TextBlock x:Name="TimeText"
                       FontSize="24"
                       FontFamily="Consolas"
                       Foreground="#34D399"
                       HorizontalAlignment="Center"
                       Margin="0,24,0,0"
                       Text=""/>
            <TextBlock x:Name="ConnectionText"
                       FontSize="12"
                       Foreground="#71717A"
                       HorizontalAlignment="Center"
                       Margin="0,32,0,0"
                       Text="Connexion au serveur..."/>
        </StackPanel>

        <Border x:Name="PostpaidBarPanel"
                Visibility="Collapsed"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Right"
                Margin="24"
                Background="#18181B"
                BorderBrush="#2563EB"
                BorderThickness="2"
                CornerRadius="8"
                Padding="16">
            <StackPanel>
                <TextBlock x:Name="PostpaidTimeText"
                           FontSize="16"
                           FontFamily="Consolas"
                           Foreground="#60A5FA"
                           Text="Session libre — 0 min"/>
                <TextBlock x:Name="PostpaidAmountText"
                           FontSize="14"
                           Foreground="#A1A1AA"
                           Margin="0,4,0,12"
                           Text="0 Ar"/>
                <Button x:Name="PostpaidStopButton"
                        Content="Terminer la session"
                        Width="200"
                        Height="36"
                        Background="#DC2626"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="13"
                        Cursor="Hand"
                        Click="PostpaidStopButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
